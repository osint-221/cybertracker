{
  "version": 8,
  "name": "CyberTracker Dark",
  "metadata": {
    "mapbox:owner": "mapbox",
    "mapbox::type": "template"
  },
  "sources": {
    "mapbox://mapbox.mapbox-streets-v8": {
      "url": "mapbox://mapbox.mapbox-streets-v8",
      "type": "vector"
    }
  },
  "sprite": "mapbox://sprites/mapbox/dark-v11",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0a0e17"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "water",
      "paint": {
        "fill-color": "#0d1b2a",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#1a1a2e",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "mountain",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "mountain",
      "paint": {
        "fill-color": "#16213e",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "park",
      "paint": {
        "fill-color": "#0f3460",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "airport",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "airport",
      "paint": {
        "fill-color": "#1a1a2e",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "military",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "military",
      "paint": {
        "fill-color": "#2d132c",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "road",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#2d3436",
        "line-width": 1.5,
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "road",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#1e272e",
        "line-width": 1,
        "line-opacity": 0.4
      }
    },
    {
      "id": "road-street",
      "type": "line",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "road",
      "filter": ["==", "class", "street"],
      "paint": {
        "line-color": "#1e272e",
        "line-width": 0.8,
        "line-opacity": 0.3
      }
    },
    {
      "id": "road-rail",
      "type": "line",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "road",
      "filter": ["==", "class", "rail"],
      "paint": {
        "line-color": "#636e72",
        "line-width": 0.8,
        "line-opacity": 0.3,
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "building",
      "paint": {
        "fill-color": "#1a1a2e",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "water-line",
      "type": "line",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "water",
      "paint": {
        "line-color": "#00cec9",
        "line-width": 0.5,
        "line-opacity": 0.3
      }
    },
    {
      "id": "country-label",
      "type": "symbol",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "country_label",
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Bold"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#74b9ff",
        "text-halo-color": "#0a0e17",
        "text-halo-width": 2,
        "text-opacity": 0.6
      }
    },
    {
      "id": "state-label",
      "type": "symbol",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "state_label",
      "layout": {
        "text-field": "{name}",
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Bold"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#636e72",
        "text-halo-color": "#0a0e17",
        "text-halo-width": 1.5,
        "text-opacity": 0.5
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "place_label",
      "filter": ["==", "type", "city"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Bold"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#b2bec3",
        "text-halo-color": "#0a0e17",
        "text-halo-width": 1.5,
        "text-opacity": 0.7
      }
    },
    {
      "id": "place-label-town",
      "type": "symbol",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "place_label",
      "filter": ["==", "type", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Bold"],
        "text-size": 9
      },
      "paint": {
        "text-color": "#636e72",
        "text-halo-color": "#0a0e17",
        "text-halo-width": 1,
        "text-opacity": 0.5
      }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "mapbox://mapbox.mapbox-streets-v8",
      "source-layer": "place_label",
      "filter": ["==", "type", "village"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": 8
      },
      "paint": {
        "text-color": "#636e72",
        "text-halo-color": "#0a0e17",
        "text-halo-width": 1,
        "text-opacity": 0.4
      }
    }
  ],
  "tolerance": 3
}